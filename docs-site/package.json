{
  "name": "rdp-js-docs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "copy-assets": "node scripts/copy-assets.mjs",
    "diagrams": "bash scripts/render-diagrams.sh",
    "render-header": "tsx scripts/render-site-header.tsx",
    "predevelop": "npm run copy-assets && npm run diagrams && npm run render-header",
    "develop": "NODE_OPTIONS=--max-old-space-size=4096 gatsby develop",
    "prebuild": "npm run copy-assets && npm run diagrams && npm run render-header",
    "build": "NODE_OPTIONS=--max-old-space-size=4096 gatsby build --prefix-paths",
    "serve": "gatsby serve --prefix-paths",
    "clean": "gatsby clean"
  },
  "dependencies": {
    "@mdx-js/react": "^2.0.0",
    "@monaco-editor/react": "^4.7.0",
    "@shikijs/rehype": "^1.0.0",
    "gatsby": "^5.16.1",
    "gatsby-plugin-mdx": "^5.16.0",
    "gatsby-source-filesystem": "^5.16.0",
    "railroad-diagrams": "1.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^3.0.1",
    "shiki": "^1.0.0"
  },
  "devDependencies": {
    "typedoc": "^0.28.19",
    "tsx": "^4.19.0",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-private-methods": "^7.18.6",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.3.0"
  }
}
