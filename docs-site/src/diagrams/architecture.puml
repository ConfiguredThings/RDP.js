@startuml architecture
skinparam componentStyle rectangle
skinparam defaultFontName monospace
skinparam packageStyle rectangle
skinparam ArrowColor #2d4a70
skinparam ArrowFontColor #2d4a70
skinparam ArrowFontSize 10
skinparam ComponentBorderColor #0056A3
skinparam ComponentBorderThickness 1.5
skinparam ComponentBackgroundColor #cce8ff
skinparam PackageBorderColor #7aaacc
skinparam PackageBorderThickness 1.5
skinparam BackgroundColor transparent

skinparam component<<key>> {
  BackgroundColor #0056A3
  FontColor white
  BorderColor #003d7a
}

top to bottom direction

together {
  package "Your code" #eef3fa {
    component "grammar.ebnf" as grammar
    component "Generated Parser.ts" as generated
    component "Hand-crafted parser" as handcrafted
  }

  package "Toolchain (build-time)" #dce8f5 {
    component "rdp-gen CLI" as rdpgen
    component "ABNFParser" as abnf
    component "EBNFParser" as ebnf
    component "GrammarParser" <<key>> as grammarparser
    component "codegen.ts" as codegen
  }
}

together {
  package "Interpreter" #b8d4eb {
    component "GrammarInterpreter" <<key>> as interp
    component "Playground / tooling" as playground
  }

  package "Runtime - shared foundation" #7aaacc {
    component "RDParser" <<key>> as rdparser
    component "ObservableRDParser" as observable
  }
}

' Toolchain build-time flow
grammar -right-> rdpgen
rdpgen -right-> abnf
rdpgen -right-> ebnf
abnf -right-> grammarparser : extends
ebnf -right-> grammarparser : extends
grammarparser -right-> codegen : AST
codegen -right-> generated : emits

' All extends relationships lead to RDParser
grammarparser -down-> rdparser : extends
generated -down-> rdparser : extends
handcrafted -down-> rdparser : extends
interp -down-> rdparser : extends
observable -down-> rdparser : extends

' Alternative interpreter path (runtime, no code generation)
grammar ..> interp : runtime path\n(no code generation)
interp -right-> playground : drives

@enduml
