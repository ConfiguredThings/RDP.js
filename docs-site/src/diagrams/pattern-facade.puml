@startuml pattern-facade
skinparam componentStyle rectangle
skinparam defaultFontName monospace
skinparam ArrowColor #2d4a70
skinparam ArrowFontColor #2d4a70
skinparam ArrowFontSize 10
skinparam ComponentBorderColor #0056A3
skinparam ComponentBorderThickness 1.5
skinparam ComponentBackgroundColor #cce8ff
skinparam PackageBorderColor #7aaacc
skinparam PackageBorderThickness 1.5
skinparam BackgroundColor transparent

skinparam component<<key>> {
  BackgroundColor #0056A3
  FontColor white
  BorderColor #003d7a
}

skinparam component<<hidden>> {
  BackgroundColor #e8e8e8
  FontColor #666666
  BorderColor #aaaaaa
}

top to bottom direction

() " string " as input

package "facade module  (e.g. date.ts)" #eef3fa {
  component "parseDate()" <<key>> as fn
  component "GeneratedParser" <<hidden>> as parser
  component "XxxNode types" <<hidden>> as nodetypes
  fn -right-> parser : uses internally
  parser -[hidden]-> nodetypes
}

() " CalendarDate " as output
() " InvalidDateError " as err

input -down-> fn
fn -down-> output : returns
fn -down-> err : throws
output -[hidden]-> err

@enduml
